{
  "manifest_version": 3,
  "name": "Rallied AI - Ticket Chat",
  "version": "0.1.0",
  "description": "Chat with your AI agent while working on PSA tickets",
  "permissions": ["sidePanel", "activeTab", "tabs", "storage"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.myconnectwise.net/*", "*://*.connectwise.com/*", "*://*.halopsa.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Rallied AI Chat"
  },
  "host_permissions": [
    "*://*.myconnectwise.net/*",
    "*://*.connectwise.com/*",
    "*://*.halopsa.com/*"
  ]
}
